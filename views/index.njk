{% extends "views/_template.njk" %}

{% block content %}
<section class="container-fluid bg-light">
   <div class="container py-5 ">
      <div class="row flex-column justify-content-center text-center align-items-center">
         <h1 class="display-3 fw-bold"> Empowering Your <span class="text-primary">Financial Future</span></h1>
         <div class="col-8">
            <p class="py-3 fs-5 text-secondary">
               Tailored investment strategies for discerning investors. Experience
               professional portfolio management with expertise, transparency, and
               unwavering trust.
            </p>
         </div>
         <div class="d-flex justify-content-center gap-3">
            <button class="btn btn-primary text-light px-4">Schedule a Consultation <i class="bi bi-arrow-right"></i> </button>
            <button class="btn btn-outline-primary ">Learn More</button>
         </div>
      </div>
   </div>
</section>
<section class="container py-5">
   <div class="row justify-content-center">
      <div class="col-6 d-flex flex-column justify-content-around">
         <h2>Who We Are</h2>
         <p>
            At PMS Investment Services, we understand that your wealth deserves
            a careful and strategic approach. With over two decades of
            experience in portfolio management, we've built our reputation on
            delivering exceptional results for high-net-worth individuals and
            institutional clients.
         </p>
         <p>
            Our team of seasoned investment professionals combines deep market
            knowledge with cutting-edge analytical tools to create personalized
            investment strategies that align with your financial goals and risk
            tolerance.
         </p>
         <section class="d-flex gap-4">
            <div class="col-3 text-center">
               <h3 class="text-primary fw-bold">20+</h3>
               <p>Years Experience</p>
            </div>
            <div class="col-5 text-center">
               <h3 class="text-primary fw-bold">500CR+</h3>
               <p>Assets Under Management</p>
            </div>
            <div class="col-3 text-center">
               <h3 class="text-primary fw-bold">200+</h3>
               <p>Satisfied Clients</p>
            </div>
         </section>
      </div>
      <div class="col-5">
         <img class="img-fluid rounded" src="https://picsum.photos/600" alt="immagine a caso" />
      </div>
   </div>
</section>

<div class="container py-5 text-center">
   <h3>Why Choose Our PMS?</h3>
   <p>
      We offer more than just investment management – we provide a
      comprehensive wealth management experience
   </p>

   <div class="row justify-content-center py-3">
      <div class="col-3 d-flex flex-column">
         <div class="card shadow border-0">
            <div class="card-body">
               <i class="bi bi-0-circle mb-3 fs-2 text-primary"></i>
               <h4 class="card-subtitle mb-2 fw-bold py-3">
                  Risk Management
               </h4>
               <p class="card-text">
                  Advanced risk assessment and mitigation strategies to protect your wealth while maximizing growth
                  potential.
               </p>

            </div>
         </div>
      </div>

      <div class="col-3 d-flex flex-column">
         <div class="card shadow border-0">
            <div class="card-body">
               <i class="bi bi-0-circle mb-3 fs-2 text-primary"></i>
               <h4 class="card-subtitle mb-2 fw-bold py-3">
                  Risk Management
               </h4>
               <p class="card-text">
                  Advanced risk assessment and mitigation strategies to protect your wealth while maximizing growth
                  potential.
               </p>

            </div>
         </div>
      </div>

      <div class="col-3 d-flex flex-column">
         <div class="card shadow border-0">
            <div class="card-body">
               <i class="bi bi-0-circle mb-3 fs-2 text-primary"></i>
               <h4 class="card-subtitle mb-2 fw-bold py-3">
                  Risk Management
               </h4>
               <p class="card-text">
                  Advanced risk assessment and mitigation strategies to protect your wealth while maximizing growth
                  potential.
               </p>

            </div>
         </div>
      </div>
   </div>
</div>

<section class="container py-3">
   <div class="text-center">
      <h2 class="fs-1 fw-bold text-dark">Our Investment Philosophy</h2>
      <p class="fs-5">We believe in transparency, integrity, and dedication to your financial success.</p>
   </div>

   <div class="row mt-5">
      <div class="col-12 col-md-6 d-flex flex-column justify-content-center gap-4">
         <div>
            <h6 class="fs-5 fw-bold"><i class="bi bi-check-lg text-primary"></i> Research-Driven Approach</h6>
            <p class="ms-4 fs-5">Comprehensive fundamental and technical analysis guides every investment decision.
            </p>
         </div>
         <div>
            <h6 class="fs-5 fw-bold"><i class="bi bi-check-lg text-primary"></i> Long-term Value Creation</h6>
            <p class="ms-4 fs-5">Focus on sustainable growth and wealth preservation over market cycles.</p>
         </div>
         <div>
            <h6 class="fs-5 fw-bold"><i class="bi bi-check-lg text-primary"></i> Diversification Strategy</h6>
            <p class="ms-4 fs-5">Balanced portfolios across asset classes, sectors, and geographies.</p>
         </div>
         <div>
            <h6 class="fs-5 fw-bold"><i class="bi bi-check-lg text-primary"></i> Transparent Communication</h6>
            <p class="ms-4 fs-5">Regular reporting and open dialogue about portfolio performance and strategy.</p>
         </div>
      </div>
      <div class="col-12 col-md-6">
         <img class="img-fluid rounded" src="https://picsum.photos/600" alt="immagine a caso" />

      </div>
   </div>
</section>


{% endblock %}